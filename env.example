# Sigillum — Variables de entorno requeridas
# Copia este archivo como .env y completa los valores.
# El .env NUNCA se sube al repositorio (ver .gitignore).
#
# Uso en compilación:
#   flutter build apk --dart-define=ANTHROPIC_API_KEY=sk-ant-...
#   flutter build ios --dart-define=ANTHROPIC_API_KEY=sk-ant-...
#   flutter run --dart-define=ANTHROPIC_API_KEY=sk-ant-...
#
# Requisito Zero Data Retention:
#   La API key debe pertenecer a una organización con contrato ZDR activo
#   o estar configurada con "Usage Policy: No Training" en console.anthropic.com.

ANTHROPIC_API_KEY=sk-ant-REEMPLAZA_CON_TU_KEY
